---
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  data: FaqItem[];
  heading?: string;
}

const { data, heading = 'Frequently Asked Questions' } = Astro.props;
---

<section class="py-20 bg-white" id="faq">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section label -->
    <div class="flex items-center gap-3 mb-4 justify-center">
      <div class="h-px w-12 bg-cta-500" />
      <span class="text-cta-600 text-xs font-bold uppercase tracking-widest">FAQ</span>
      <div class="h-px w-12 bg-cta-500" />
    </div>

    <h2 class="text-3xl md:text-4xl font-extrabold text-ink-900 text-center tracking-tighter mb-12">
      {heading}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
      {data.map((item, i) => (
        <details class="group bg-white border border-surface-border rounded-xl overflow-hidden hover:border-brand-200 transition-colors self-start">
          <summary class="flex items-center justify-between px-6 py-5 cursor-pointer select-none gap-4">
            <h3 class="text-sm font-semibold text-ink-800 text-left group-open:text-brand-700 transition-colors">{item.q}</h3>
            <div class="w-7 h-7 rounded-full border border-surface-border flex items-center justify-center flex-shrink-0 group-open:bg-brand-700 group-open:border-brand-700 transition-all duration-200">
              <svg
                class="faq-icon w-3.5 h-3.5 text-ink-500 group-open:text-white transition-colors"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </summary>
          <div class="faq-body px-6 pb-5 border-t border-surface-line">
            <p class="text-ink-600 text-sm leading-relaxed pt-4">{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
