---
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  data: FaqItem[];
  heading?: string;
  schema?: boolean;
}

const { data, heading = 'Frequently Asked Questions', schema = true } = Astro.props;
---

<section class="py-16 bg-surface-soft" id="faq">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-bold text-ink-800 text-center mb-10 tracking-tight">
      {heading}
    </h2>

    <div class="space-y-3">
      {data.map((item, i) => (
        <details class="bg-white rounded-lg border border-surface-border shadow-sm group">
          <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none">
            <h3 class="text-base font-semibold text-ink-800 pr-4 text-left">{item.q}</h3>
            <svg
              class="faq-icon w-5 h-5 text-brand-600 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="faq-body px-6 pb-5">
            <p class="text-ink-600 text-sm leading-relaxed">{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
