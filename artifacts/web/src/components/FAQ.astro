---
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  data: FaqItem[];
  heading?: string;
}

const { data, heading = 'Frequently Asked Questions' } = Astro.props;
---

<section class="pt-24 pb-32 bg-surface-soft" id="faq">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section label -->
    <div class="flex items-center gap-3 mb-5 justify-center">
      <div class="h-px w-14 bg-cta-500" />
      <span class="text-cta-600 text-xs font-bold uppercase tracking-widest">FAQ</span>
      <div class="h-px w-14 bg-cta-500" />
    </div>

    <h2 class="text-3xl md:text-4xl font-extrabold text-ink-900 text-center tracking-tighter mb-14">
      {heading}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {data.map((item) => (
        <details class="group bg-white border border-surface-border rounded-2xl overflow-hidden hover:border-brand-300 hover:shadow-lg hover:shadow-brand-900/6 transition-all duration-300 self-start">
          <summary class="flex items-start justify-between px-7 py-6 cursor-pointer select-none gap-5">
            <h3 class="text-base font-semibold text-ink-800 text-left leading-snug group-open:text-brand-700 transition-colors pt-0.5">
              {item.q}
            </h3>
            <div class="w-8 h-8 rounded-full border-2 border-surface-border flex items-center justify-center flex-shrink-0 group-open:bg-brand-700 group-open:border-brand-700 transition-all duration-200 mt-0.5">
              <svg
                class="w-3.5 h-3.5 text-ink-400 group-open:text-white transition-all duration-200 group-open:rotate-180"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </summary>
          <div class="px-7 pb-7 border-t border-surface-line">
            <p class="text-ink-600 text-sm leading-relaxed pt-5">{item.a}</p>
            <p class="flex items-center gap-1.5 mt-4 text-xs text-ink-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-brand-600 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
              </svg>
              Reviewed by <strong class="text-ink-600 font-semibold">Jorge V. Canellas, RZ3108</strong> — Certified General Appraiser
            </p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
