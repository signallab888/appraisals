---
import business from '../data/business.json';
---

<header class="bg-brand-700 shadow-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
    <!-- Logo only — no nav menu on LP -->
    <a href="/" aria-label="Appraisers of America — Home">
      <img
        src="/logo.svg"
        alt="Appraisers of America"
        width="160"
        height="44"
        loading="eager"
        fetchpriority="high"
        class="h-9 w-auto"
      />
    </a>

    <!-- Phone CTA only -->
    <a
      href={`tel:${business.phones.primary}`}
      class="bg-cta-600 hover:bg-cta-700 text-white font-medium rounded-md px-4 py-2.5 text-sm transition-colors flex items-center gap-2"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
      </svg>
      {business.phones.primary_display}
    </a>
  </div>
</header>
