---
import propertyTypes from '../data/property-types.json';

interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<section class={`${compact ? 'py-12' : 'py-20'} bg-surface-soft`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {!compact && (
      <>
        <div class="flex items-center gap-3 mb-4 justify-center">
          <div class="h-px w-12 bg-cta-500" />
          <span class="text-cta-600 text-xs font-bold uppercase tracking-widest">Property Types</span>
          <div class="h-px w-12 bg-cta-500" />
        </div>
        <h2 class="text-3xl md:text-4xl font-extrabold text-ink-900 text-center tracking-tighter mb-4">
          Every Commercial Property Type in Florida
        </h2>
        <p class="text-ink-500 text-center text-base mb-12 max-w-xl mx-auto">
          From office buildings to marinas — if it's commercial, we appraise it.
        </p>
      </>
    )}
    {compact && (
      <h3 class="text-xl font-bold text-ink-900 mb-6 tracking-tight">Property Types We Appraise</h3>
    )}

    <div class={`grid gap-3 ${compact ? 'grid-cols-2 sm:grid-cols-3 md:grid-cols-4' : 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-4'}`}>
      {propertyTypes.map(pt => (
        <div class="group bg-white border border-surface-border rounded-xl p-4 hover:border-brand-400 hover:shadow-lg hover:shadow-brand-900/8 transition-all duration-250 hover:-translate-y-0.5 cursor-default">
          <div class="w-9 h-9 rounded-lg bg-brand-50 border border-brand-100 flex items-center justify-center mb-3 group-hover:bg-brand-700 group-hover:border-brand-700 transition-all duration-250">
            <svg class="w-4.5 h-4.5 text-brand-600 group-hover:text-white transition-colors duration-250" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <p class="font-semibold text-ink-800 text-sm leading-tight group-hover:text-brand-700 transition-colors">{pt.name}</p>
          {!compact && <p class="text-ink-500 text-xs mt-1 leading-snug">{pt.blurb}</p>}
        </div>
      ))}
    </div>
  </div>
</section>
