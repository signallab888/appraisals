---
import QuoteForm from './QuoteForm.astro';
import business from '../data/business.json';

interface Props {
  h1: string;
  subtitle: string;
  officeLine: string;
  phone: 'primary' | 'secondary';
}

const { h1, subtitle, officeLine, phone } = Astro.props;
const phoneDisplay = phone === 'primary' ? business.phones.primary_display : business.phones.secondary_display;
const phoneTel = phone === 'primary' ? business.phones.primary : business.phones.secondary;
---

<section class="bg-brand-700 text-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

      <!-- Left: copy -->
      <div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white tracking-tight mb-4">
          {h1}
        </h1>
        <p class="text-lg text-brand-200 mb-3 leading-relaxed">{subtitle}</p>
        <p class="text-sm text-brand-300 mb-6">{officeLine}</p>

        <a
          href={`tel:${phoneTel}`}
          class="inline-flex items-center gap-2 bg-cta-600 hover:bg-cta-700 text-white font-medium rounded-md px-6 py-3 text-base transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
          </svg>
          Call {phoneDisplay}
        </a>
      </div>

      <!-- Right: form sticky -->
      <div class="lg:sticky lg:top-24">
        <QuoteForm source="lp" heading="Free Quote in 2 Hours" id="quote" />
        <p class="text-brand-300 text-xs text-center mt-2">{officeLine} · Response in 2 business hours.</p>
      </div>

    </div>
  </div>
</section>
