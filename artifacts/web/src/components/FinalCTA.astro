---
import QuoteForm from './QuoteForm.astro';
import business from '../data/business.json';
import { Image } from 'astro:assets';
import heroBg from '../assets/hero/frames/frame_05s.jpg';
---

<section class="py-24 text-white relative overflow-hidden" id="contact">
  <!-- Video frame background -->
  <Image
    src={heroBg}
    alt=""
    class="absolute inset-0 w-full h-full object-cover scale-105" style="object-position: center 20%;"
    aria-hidden="true"
    widths={[800, 1280, 1920]}
    sizes="100vw"
    loading="lazy"
  />

  <!-- Layer 1: solid dark base -->
  <div class="absolute inset-0 bg-brand-950/80" />

  <!-- Layer 2: directional gradient — very dark left (text side), clears on right to reveal photo -->
  <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(8,15,30,0.75) 0%, rgba(8,15,30,0.45) 55%, rgba(8,15,30,0.15) 100%);" />

  <!-- Layer 3: subtle top/bottom vignette for depth -->
  <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(8,15,30,0.4) 0%, transparent 25%, transparent 75%, rgba(8,15,30,0.5) 100%);" />

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">

      <!-- Left: copy -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px w-10 bg-cta-500" />
          <span class="text-cta-400 text-xs font-bold uppercase tracking-widest">Get Started</span>
        </div>

        <h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tighter mb-5 leading-tight">
          Get Your Free Commercial<br class="hidden md:block" /> Appraisal Quote Today
        </h2>

        <p class="text-brand-200/80 text-base mb-10 leading-relaxed max-w-md">
          We respond within 2 business hours. Monday–Friday 8am–6pm.
          Saturday quotes available by request.
        </p>

        <!-- Quick trust stats -->
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-cta-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span class="text-white/80 text-sm">20+ years serving all 67 Florida counties</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-cta-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span class="text-white/80 text-sm">State Certified · License RZ3108 · USPAP compliant</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-cta-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span class="text-white/80 text-sm">SBA, FIRREA & lender-grade reports accepted nationwide</span>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div>
        <QuoteForm source="final-cta" heading="Request a Free Quote" id="quote-bottom" />
      </div>
    </div>
  </div>
</section>
