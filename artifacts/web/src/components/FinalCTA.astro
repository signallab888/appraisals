---
import QuoteForm from './QuoteForm.astro';
import business from '../data/business.json';
import { Image } from 'astro:assets';
import heroBg from '../assets/hero/hero-orlando-skyline.jpg';
---

<section class="py-20 text-white relative overflow-hidden" id="contact">
  <!-- Hero photo background -->
  <Image
    src={heroBg}
    alt=""
    class="absolute inset-0 w-full h-full object-cover object-center"
    aria-hidden="true"
    widths={[800, 1280, 1920]}
    sizes="100vw"
    loading="lazy"
  />
  <!-- Dark overlay so text stays readable -->
  <div class="absolute inset-0 bg-brand-950/85" />
  <!-- Subtle color accent -->
  <div class="absolute inset-0 opacity-15" style="background: radial-gradient(ellipse at 20% 50%, #3568a6 0%, transparent 55%), radial-gradient(ellipse at 80% 50%, #ea580c 0%, transparent 55%);" />

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">

      <!-- Left: copy -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px w-10 bg-cta-500" />
          <span class="text-cta-400 text-xs font-bold uppercase tracking-widest">Get Started</span>
        </div>

        <h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tighter mb-5 leading-tight">
          Get Your Free Commercial<br class="hidden md:block" /> Appraisal Quote Today
        </h2>

        <p class="text-brand-300 text-base mb-8 leading-relaxed max-w-md">
          We respond within 2 business hours. Monday–Friday 8am–6pm.
          Saturday quotes available by request.
        </p>

        <!-- Contact options -->
        <div class="space-y-3 mb-8">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-white/8 border border-white/12 flex items-center justify-center flex-shrink-0">
              <svg class="w-4.5 h-4.5 text-brand-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
              </svg>
            </div>
            <div>
              <p class="text-brand-400 text-xs font-medium">{business.phones.primary_label}</p>
              <a href={`tel:${business.phones.primary}`} class="text-white font-bold hover:text-brand-200 transition-colors text-lg leading-tight">
                {business.phones.primary_display}
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-white/8 border border-white/12 flex items-center justify-center flex-shrink-0">
              <svg class="w-4.5 h-4.5 text-brand-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <a href={`mailto:${business.email}`} class="text-brand-300 hover:text-white transition-colors">
              {business.email}
            </a>
          </div>
        </div>

        <!-- Compliance badges -->
        <div class="flex flex-wrap gap-2">
          {business.compliance.map(c => (
            <span class="bg-white/8 border border-white/15 text-brand-300 rounded-full px-3.5 py-1.5 text-xs font-semibold">{c}</span>
          ))}
          <span class="bg-white/8 border border-white/15 text-brand-300 rounded-full px-3.5 py-1.5 text-xs font-semibold">License RZ3108</span>
        </div>
      </div>

      <!-- Right: form -->
      <div>
        <QuoteForm source="final-cta" heading="Request a Free Quote" id="quote-bottom" />
      </div>
    </div>
  </div>
</section>
