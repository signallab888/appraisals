---
import testimonials from '../data/testimonials.json';
---

<section class="py-20 bg-surface-soft" id="testimonials">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section label -->
    <div class="flex items-center gap-3 mb-4 justify-center">
      <div class="h-px w-12 bg-cta-500" />
      <span class="text-cta-600 text-xs font-bold uppercase tracking-widest">Google Reviews</span>
      <div class="h-px w-12 bg-cta-500" />
    </div>

    <h2 class="text-3xl md:text-4xl font-extrabold text-ink-900 text-center tracking-tighter mb-3">
      What Our Clients Say
    </h2>

    <!-- Aggregate rating row -->
    <div class="flex items-center justify-center gap-3 mb-12">
      <!-- Google G logo -->
      <svg class="w-6 h-6 flex-shrink-0" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      <div class="flex gap-0.5" aria-label="5 stars">
        {[...Array(5)].map(() => (
          <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
      <span class="text-ink-700 font-semibold text-sm">5.0 · Verified Google Reviews</span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {testimonials.map(t => (
        <div class="bg-white rounded-2xl p-6 shadow-md shadow-ink-900/6 hover:shadow-xl hover:shadow-ink-900/10 transition-all duration-300 hover:-translate-y-1 border border-surface-line/60 flex flex-col">

          <!-- Reviewer header -->
          <div class="flex items-start gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-brand-700 flex items-center justify-center text-white text-sm font-bold flex-shrink-0 uppercase">
              {t.name.charAt(0)}
            </div>
            <div class="min-w-0">
              <p class="font-bold text-ink-900 text-sm leading-tight truncate">{t.name}</p>
              <p class="text-ink-400 text-xs leading-tight mt-0.5">
                {t.badge && <span class="text-blue-600 font-medium">{t.badge} · </span>}
                {t.reviewCount} reviews
              </p>
            </div>
          </div>

          <!-- Stars + time -->
          <div class="flex items-center gap-2 mb-3">
            <div class="flex gap-0.5" aria-label="5 stars">
              {[...Array(5)].map(() => (
                <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-ink-400 text-xs">{t.timeAgo}</span>
          </div>

          <!-- Quote -->
          <blockquote class="text-ink-700 text-sm leading-relaxed flex-1">
            {t.quote}
          </blockquote>

        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="https://www.google.com/maps/search/Appraisers+of+America+Inc+Orlando+FL"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-brand-600 hover:text-brand-700 font-semibold text-sm transition-colors group"
      >
        Read All Reviews on Google
        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
