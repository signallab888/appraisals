---
import testimonials from '../data/testimonials.json';
---

<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-bold text-ink-800 tracking-tight">
        What Our Clients Say
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {testimonials.map(t => (
        <div class="bg-surface-soft rounded-lg p-6 border border-surface-line shadow-sm hover:shadow-md transition-shadow">
          <div class="flex mb-3" aria-label="5 stars">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="text-ink-700 text-sm leading-relaxed mb-4">
            "{t.quote}"
          </blockquote>
          <div>
            <p class="font-semibold text-ink-800 text-sm">{t.name}</p>
            <p class="text-ink-500 text-xs">{t.role}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-8">
      <a
        href="https://www.google.com/maps/search/Appraisers+of+America"
        target="_blank"
        rel="noopener noreferrer"
        class="text-brand-600 hover:text-brand-700 font-medium text-sm transition-colors"
      >
        Read All Reviews on Google →
      </a>
    </div>
  </div>
</section>
