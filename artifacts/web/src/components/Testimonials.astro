---
import testimonials from '../data/testimonials.json';
---

<section class="py-20 bg-surface-soft">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section label -->
    <div class="flex items-center gap-3 mb-4 justify-center">
      <div class="h-px w-12 bg-cta-500" />
      <span class="text-cta-600 text-xs font-bold uppercase tracking-widest">Client Results</span>
      <div class="h-px w-12 bg-cta-500" />
    </div>

    <h2 class="text-3xl md:text-4xl font-extrabold text-ink-900 text-center tracking-tighter mb-12">
      What Our Clients Say
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {testimonials.map(t => (
        <div class="bg-white rounded-2xl p-6 shadow-md shadow-ink-900/6 hover:shadow-xl hover:shadow-ink-900/10 transition-all duration-300 hover:-translate-y-1 border border-surface-line/60 flex flex-col">
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4" aria-label="5 stars">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Large quote mark -->
          <div class="text-brand-100 font-serif text-5xl leading-none mb-2 select-none">"</div>

          <blockquote class="text-ink-700 text-sm leading-relaxed flex-1 mb-5 -mt-3">
            {t.quote}
          </blockquote>

          <div class="flex items-center gap-3 pt-4 border-t border-surface-line">
            <div class="w-9 h-9 rounded-full bg-brand-700 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
              {t.name.charAt(0)}
            </div>
            <div>
              <p class="font-bold text-ink-900 text-sm">{t.name}</p>
              <p class="text-ink-500 text-xs">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="https://www.google.com/maps/search/Appraisers+of+America"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-brand-600 hover:text-brand-700 font-semibold text-sm transition-colors group"
      >
        Read All Reviews on Google
        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
