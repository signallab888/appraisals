---
import business from '../data/business.json';
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-ink-900/8 shadow-sm shadow-ink-900/5">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0" aria-label="Appraisers of America — Home">
      <img
        src="/logo.svg"
        alt="Appraisers of America"
        width="160"
        height="44"
        loading="eager"
        fetchpriority="high"
        class="h-11 w-auto"
      />
    </a>

    <!-- Nav links -->
    <div class="hidden md:flex items-center gap-7 text-sm font-medium text-ink-600 tracking-wide">
      <a href="/#services"  class="hover:text-brand-700 transition-colors">Services</a>
      <a href="/#coverage"  class="hover:text-brand-700 transition-colors">Coverage</a>
      <a href="/#pricing"   class="hover:text-brand-700 transition-colors">Pricing</a>
      <a href="/#faq"       class="hover:text-brand-700 transition-colors">FAQ</a>
    </div>

    <!-- Right side: phone + CTA -->
    <div class="flex items-center gap-4">
      <a
        href={`tel:${business.phones.primary}`}
        class="hidden md:flex items-center gap-2 text-sm font-semibold text-ink-800 hover:text-brand-700 transition-colors"
      >
        <svg class="w-4 h-4 text-cta-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
        </svg>
        {business.phones.primary_display}
      </a>

      <a
        href="/#quote"
        class="bg-cta-600 hover:bg-cta-500 text-white font-semibold rounded-lg px-5 py-2.5 text-sm transition-all duration-200 flex-shrink-0 shadow-md shadow-cta-700/25 hover:-translate-y-0.5 hover:shadow-lg"
      >
        Get a Free Quote
      </a>
    </div>
  </nav>
</header>
