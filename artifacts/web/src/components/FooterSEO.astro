---
import business from '../data/business.json';
---

<footer class="bg-brand-900 text-brand-200 pb-16 md:pb-0">

  <!-- Main footer body -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">

      <!-- Col 1: Brand block -->
      <div class="md:col-span-4 pr-4">
        <img
          src="/logo.svg"
          alt="Appraisers of America"
          width="148"
          height="42"
          class="h-10 w-auto mb-4"
        />
        <p class="text-brand-300 text-sm leading-relaxed mb-5 max-w-xs">
          Florida's trusted commercial real estate appraisers for banks, attorneys, and property owners. Serving all 67 counties since 2004.
        </p>
        <!-- Compliance badges: 2-per-row on mobile -->
        <div class="grid grid-cols-2 sm:flex sm:flex-wrap gap-2">
          {['USPAP', 'FIRREA', 'SBA Ready', 'License RZ3108'].map(b => (
            <span class="text-xs text-brand-300 bg-brand-800 border border-brand-700 rounded px-2.5 py-1.5 font-medium text-center">{b}</span>
          ))}
        </div>
      </div>

      <!-- Col 2: Navigation — 2-column grid on mobile -->
      <div class="md:col-span-3">
        <p class="text-white text-xs font-bold uppercase tracking-widest mb-4">Quick Links</p>
        <ul class="grid grid-cols-2 md:grid-cols-1 gap-y-3 gap-x-4">
          <li><a href="/#services"  class="text-sm text-brand-300 hover:text-white transition-colors">Services</a></li>
          <li><a href="/#coverage"  class="text-sm text-brand-300 hover:text-white transition-colors">Coverage</a></li>
          <li><a href="/#pricing"   class="text-sm text-brand-300 hover:text-white transition-colors">Pricing</a></li>
          <li><a href="/#faq"       class="text-sm text-brand-300 hover:text-white transition-colors">FAQ</a></li>
          <li><a href="/#quote"     class="text-sm text-cta-400 hover:text-cta-300 font-medium transition-colors">Get a Free Quote</a></li>
        </ul>
      </div>

      <!-- Col 3: Contact -->
      <div class="md:col-span-5">
        <p class="text-white text-xs font-bold uppercase tracking-widest mb-4">Contact</p>

        <!-- Phone — tappable block on mobile -->
        <a
          href={`tel:${business.phones.primary}`}
          class="group flex items-center gap-3 bg-brand-800/60 border border-brand-700/60 rounded-xl px-4 py-3 mb-3 hover:bg-brand-800 transition-colors md:bg-transparent md:border-none md:rounded-none md:px-0 md:py-0 md:mb-5 md:items-start"
        >
          <div class="w-8 h-8 rounded-lg bg-cta-600 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
          </div>
          <div>
            <p class="text-[10px] text-brand-400 font-medium uppercase tracking-wide leading-none mb-0.5 md:text-xs md:normal-case md:tracking-normal">Phone</p>
            <p class="text-white font-bold text-base md:text-lg group-hover:text-brand-200 transition-colors leading-tight">{business.phones.primary_display}</p>
          </div>
        </a>

        <!-- Email — tappable block on mobile -->
        <a
          href={`mailto:${business.email}`}
          class="group flex items-center gap-3 bg-brand-800/60 border border-brand-700/60 rounded-xl px-4 py-3 mb-5 hover:bg-brand-800 transition-colors md:bg-transparent md:border-none md:rounded-none md:px-0 md:py-0 md:mb-5 md:items-start"
        >
          <div class="w-8 h-8 rounded-lg bg-brand-700 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-brand-300" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
              <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
            </svg>
          </div>
          <div>
            <p class="text-[10px] text-brand-400 font-medium uppercase tracking-wide leading-none mb-0.5 md:text-xs md:normal-case md:tracking-normal">Email</p>
            <p class="text-brand-200 text-sm group-hover:text-white transition-colors">{business.email}</p>
          </div>
        </a>

        <div class="border-t border-brand-800 pt-4">
          <p class="text-xs text-brand-400">{business.businessHours}</p>
          <p class="text-xs text-brand-400 mt-1">English · Español &nbsp;·&nbsp; Jorge V. Canellas, RZ3108</p>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-brand-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-brand-500">
      <p>© {new Date().getFullYear()} {business.legalName}. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="/privacy" class="hover:text-brand-300 transition-colors">Privacy Policy</a>
        <span class="text-brand-700">·</span>
        <span>State Certified General · RZ3108</span>
      </div>
    </div>
  </div>

</footer>
