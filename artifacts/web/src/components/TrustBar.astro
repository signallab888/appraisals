---
const badges = [
  { value: '20+',    label: 'Years in Florida' },
  { value: 'RZ3108', label: 'State Certified'  },
  { value: 'SBA',    label: 'Qualified'          },
  { value: 'USPAP',  label: 'Compliant'         },
  { value: 'EN/ES',  label: 'Bilingual'         },
  { value: '67',     label: 'Counties Served'   },
];
---

<div class="bg-brand-800/90 backdrop-blur-sm border-y border-brand-600/40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
    <div class="grid grid-cols-3 sm:grid-cols-6 divide-x divide-brand-600/40">
      {badges.map(b => (
        <div class="flex flex-col items-center justify-center px-3 py-1 text-center">
          <span class="text-white font-extrabold text-lg leading-none tracking-tight">{b.value}</span>
          <span class="text-brand-400 text-xs mt-0.5 whitespace-nowrap">{b.label}</span>
        </div>
      ))}
    </div>
  </div>
</div>
