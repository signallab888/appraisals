---

<section class="py-20" style="background-color:#080f1e;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="flex items-center gap-3 mb-4 justify-center">
      <div class="h-px w-12 bg-cta-600/60" />
      <span class="text-cta-400 text-xs font-bold uppercase tracking-widest">Appraisal Purposes</span>
      <div class="h-px w-12 bg-cta-600/60" />
    </div>
    <h2 class="text-3xl md:text-4xl font-extrabold text-white text-center tracking-tighter mb-3">
      Every Reason a Florida Property Needs an Appraisal
    </h2>
    <p class="text-brand-400 text-center text-base mb-14 max-w-xl mx-auto">
      Banks, courts, the IRS, and investors all rely on our certified reports.
    </p>

    <!-- 5-column grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
      {categories.map(cat => (
        <div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm px-5 py-6 flex flex-col gap-4 hover:border-white/20 hover:bg-white/8 transition-all duration-300">

          <!-- Category header -->
          <div class="flex items-center gap-3 pb-4 border-b border-white/10">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 text-cta-400" style="background-color:rgba(139,32,53,0.25);">
              <Fragment set:html={cat.icon} />
            </div>
            <p class="text-white font-bold text-sm leading-tight">{cat.label}</p>
          </div>

          <!-- Items -->
          <ul class="space-y-2.5">
            {cat.items.map(item => (
              <li class="flex items-start gap-2.5">
                <span class="mt-[5px] w-1.5 h-1.5 rounded-full bg-cta-500 flex-shrink-0" />
                <span class="text-brand-300 text-sm leading-snug">{item}</span>
              </li>
            ))}
          </ul>

        </div>
      ))}
    </div>

  </div>
</section>
