---
import QuoteForm from './QuoteForm.astro';
import business from '../data/business.json';
---

<section class="relative min-h-[92vh] flex items-center overflow-hidden bg-brand-900">
  <!-- Video background -->
  <video
    class="absolute inset-0 w-full h-full object-cover"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    aria-hidden="true"
  >
    <source src="/hero-bg.mp4" type="video/mp4" />
  </video>

  <!-- Layered gradient: dark on left, lighter on right -->
  <div class="absolute inset-0 bg-gradient-to-r from-brand-900/90 via-brand-900/70 to-brand-900/40" />
  <div class="absolute inset-0 bg-gradient-to-t from-brand-900/70 via-transparent to-transparent" />

  <!-- Content -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">

      <!-- Left: headline block -->
      <div>
        <!-- Credential pill -->
        <div class="inline-flex items-center gap-2.5 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 text-xs font-semibold text-white/90 mb-7 tracking-wide uppercase">
          <span class="w-2 h-2 rounded-full bg-cta-500 animate-pulse flex-shrink-0"></span>
          State Certified · License RZ3108
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-[4.25rem] font-extrabold text-white tracking-tighter leading-[1.05] mb-7">
          Commercial<br />
          Real Estate<br />
          <span class="text-cta-400">Appraisers</span><br />
          <span class="text-brand-200 text-4xl md:text-5xl lg:text-5xl font-semibold">in Florida</span>
        </h1>

        <p class="text-lg text-brand-200 leading-relaxed mb-9 max-w-md">
          SBA loans, refinances, divorce, estate, and tax appeals.
          {business.yearsExperience} years serving all {business.countiesServed} Florida counties.
        </p>

        <!-- Dual CTA -->
        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a
            href="#quote"
            class="bg-cta-600 hover:bg-cta-500 text-white font-semibold rounded-lg px-8 py-4 text-base transition-all duration-200 text-center shadow-lg shadow-cta-700/30 hover:shadow-xl hover:shadow-cta-700/40 hover:-translate-y-0.5"
          >
            Get a Free Quote
          </a>
          <a
            href={`tel:${business.phones.primary}`}
            class="border-2 border-white/30 hover:border-white/70 text-white font-semibold rounded-lg px-8 py-4 text-base transition-all duration-200 text-center backdrop-blur-sm hover:bg-white/10"
          >
            Call {business.phones.primary_display}
          </a>
        </div>

        <!-- Quick trust stats -->
        <div class="flex flex-wrap justify-center sm:justify-start gap-x-6 gap-y-2.5 text-sm text-brand-300">
          {[
            `${business.yearsExperience} Years`,
            `${business.countiesServed} Counties`,
            'FIRREA & USPAP',
          ].map(item => (
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-cta-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {item}
            </span>
          ))}
        </div>
      </div>

      <!-- Right: form card -->
      <div class="lg:ml-auto w-full max-w-md mx-auto lg:mx-0">
        <QuoteForm source="home" heading="Free Quote in 2 Hours" id="quote" />
      </div>

    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-brand-900/80 to-transparent pointer-events-none" />
</section>
