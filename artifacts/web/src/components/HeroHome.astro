---
import { Image } from 'astro:assets';
import heroImage from '../assets/hero/hero-orlando-skyline.jpg';
import QuoteForm from './QuoteForm.astro';
import business from '../data/business.json';
---

<section class="bg-brand-700 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

      <!-- Left: copy -->
      <div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight tracking-tight mb-6">
          Commercial Real Estate Appraiser in Florida
        </h1>
        <p class="text-lg md:text-xl text-brand-200 mb-8 leading-relaxed">
          State-certified commercial appraisals for SBA loans, refinances,
          divorce, estate, and tax appeals. {business.yearsExperience} years across all {business.countiesServed} Florida counties.
        </p>

        <!-- Dual CTA -->
        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a
            href="#quote"
            class="bg-cta-600 hover:bg-cta-700 text-white font-medium rounded-md px-7 py-3.5 text-base transition-colors text-center"
          >
            Get a Free Quote
          </a>
          <a
            href={`tel:${business.phones.primary}`}
            class="border border-white text-white hover:bg-white hover:text-brand-700 font-medium rounded-md px-7 py-3.5 text-base transition-colors text-center"
          >
            Call {business.phones.primary_display}
          </a>
        </div>

        <!-- Hero image — mobile visible, desktop hidden (image moves to right side) -->
        <div class="lg:hidden rounded-xl overflow-hidden shadow-lg">
          <Image
            src={heroImage}
            alt="Orlando commercial skyline — Appraisers of America serves all of Florida"
            loading="eager"
            fetchpriority="high"
            width={680}
            height={420}
            class="w-full h-56 object-cover"
          />
        </div>
      </div>

      <!-- Right: quote form -->
      <div class="relative">
        <!-- Desktop hero image behind form -->
        <div class="hidden lg:block absolute inset-0 -bottom-8 -right-8 -top-8 rounded-xl overflow-hidden opacity-30">
          <Image
            src={heroImage}
            alt="Orlando commercial skyline"
            loading="eager"
            fetchpriority="high"
            width={700}
            height={500}
            class="w-full h-full object-cover"
          />
        </div>
        <div class="relative z-10">
          <QuoteForm source="home" heading="Free Quote in 2 Hours" id="quote" />
        </div>
      </div>

    </div>
  </div>
</section>
