---
interface Props {
  source?: string;
  heading?: string;
  id?: string;
}
const { source = 'home', heading = 'Free Quote in 2 Hours', id = 'quote' } = Astro.props;
const formId = `qf-${source}-${id}`;
---

<div class="rounded-2xl overflow-hidden" id={id} style="box-shadow: 0 24px 80px rgba(10,14,26,0.38), 0 0 0 1px rgba(255,255,255,0.08);">
  <!-- Premium header band -->
  <div class="bg-gradient-to-br from-brand-700 to-brand-800 px-7 py-5">
    <div class="flex items-center gap-2 mb-1">
      <div class="w-2 h-2 rounded-full bg-cta-500"></div>
      <h3 class="text-white font-bold text-xl tracking-tight">{heading}</h3>
    </div>
    <p class="text-brand-300 text-sm pl-4">No commitment · We call you back</p>
  </div>

  <!-- White form body -->
  <div class="bg-white px-7 py-6">
    <form
      id={formId}
      class="space-y-4"
      action="https://formspree.io/f/xxxxxxx"
      method="POST"
      data-source={source}
    >
      <div>
        <label for={`${formId}-name`} class="block text-xs font-semibold text-ink-500 uppercase tracking-wider mb-1.5">
          Full Name <span class="text-semantic-error">*</span>
        </label>
        <input
          type="text"
          id={`${formId}-name`}
          name="name"
          required
          placeholder="Your full name"
          class="w-full rounded-lg border border-surface-border bg-surface-soft px-4 py-3 text-ink-800 text-sm placeholder:text-ink-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 focus:bg-white transition-all"
        />
      </div>

      <div>
        <label for={`${formId}-phone`} class="block text-xs font-semibold text-ink-500 uppercase tracking-wider mb-1.5">
          Phone <span class="text-semantic-error">*</span>
        </label>
        <input
          type="tel"
          id={`${formId}-phone`}
          name="phone"
          required
          placeholder="(407) 000-0000"
          class="w-full rounded-lg border border-surface-border bg-surface-soft px-4 py-3 text-ink-800 text-sm placeholder:text-ink-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 focus:bg-white transition-all"
        />
      </div>

      <div>
        <label for={`${formId}-address`} class="block text-xs font-semibold text-ink-500 uppercase tracking-wider mb-1.5">
          Property Address <span class="text-semantic-error">*</span>
        </label>
        <input
          type="text"
          id={`${formId}-address`}
          name="address"
          required
          placeholder="123 Main St, Orlando, FL"
          class="w-full rounded-lg border border-surface-border bg-surface-soft px-4 py-3 text-ink-800 text-sm placeholder:text-ink-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 focus:bg-white transition-all"
        />
      </div>

      <button
        type="submit"
        class="submit-btn w-full bg-cta-600 hover:bg-cta-500 text-white font-bold rounded-lg px-6 py-3.5 text-sm transition-all duration-200 mt-2 shadow-md shadow-cta-700/30 hover:shadow-lg hover:shadow-cta-700/40 hover:-translate-y-0.5"
      >
        Get My Free Quote →
      </button>

      <div class="success-msg hidden text-center py-3">
        <p class="text-semantic-success font-semibold text-sm">✓ Got it. We'll call you within 2 hours.</p>
      </div>
    </form>

    <!-- Micro-trust line -->
    <div class="mt-4 pt-4 border-t border-surface-line flex items-center justify-center gap-3 text-xs text-ink-400">
      <span class="flex items-center gap-1">
        <svg class="w-3 h-3 text-semantic-success" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
        Secure
      </span>
      <span>·</span>
      <span>Response in 2 hrs</span>
      <span>·</span>
      <span>No spam</span>
    </div>
  </div>
</div>

<script define:vars={{ formId, source }}>
  const form = document.getElementById(formId);
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('.submit-btn');
      const msg = form.querySelector('.success-msg');
      btn.disabled = true;
      btn.textContent = 'Sending…';
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.reset();
          msg.classList.remove('hidden');
          btn.classList.add('hidden');
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'quote_submitted', source });
        } else {
          btn.textContent = 'Try Again';
          btn.disabled = false;
        }
      } catch {
        btn.textContent = 'Try Again';
        btn.disabled = false;
      }
    });
  }
</script>
