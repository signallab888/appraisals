---
interface Props {
  source?: string;
  heading?: string;
  id?: string;
}
const { source = 'home', heading = 'Free Quote in 2 Hours', id = 'quote' } = Astro.props;
const formId = `qf-${source}-${id}`;
---

<div class="bg-white rounded-xl shadow-xl p-6 md:p-8" id={id}>
  <h3 class="text-xl font-semibold text-ink-800 mb-1">{heading}</h3>
  <p class="text-sm text-ink-500 mb-5">We'll call you back within 2 business hours.</p>

  <form
    id={formId}
    class="space-y-4"
    action="https://formspree.io/f/xxxxxxx"
    method="POST"
    data-source={source}
  >
    <div>
      <label for={`${formId}-name`} class="block text-sm font-medium text-ink-700 mb-1">
        Full Name <span class="text-semantic-error">*</span>
      </label>
      <input
        type="text"
        id={`${formId}-name`}
        name="name"
        required
        placeholder="Your full name"
        class="w-full rounded-md border border-surface-border px-4 py-3 text-ink-800 placeholder:text-ink-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
      />
    </div>

    <div>
      <label for={`${formId}-phone`} class="block text-sm font-medium text-ink-700 mb-1">
        Phone <span class="text-semantic-error">*</span>
      </label>
      <input
        type="tel"
        id={`${formId}-phone`}
        name="phone"
        required
        placeholder="(407) 000-0000"
        class="w-full rounded-md border border-surface-border px-4 py-3 text-ink-800 placeholder:text-ink-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
      />
    </div>

    <div>
      <label for={`${formId}-address`} class="block text-sm font-medium text-ink-700 mb-1">
        Property Address <span class="text-semantic-error">*</span>
      </label>
      <input
        type="text"
        id={`${formId}-address`}
        name="address"
        required
        placeholder="123 Main St, Orlando, FL"
        class="w-full rounded-md border border-surface-border px-4 py-3 text-ink-800 placeholder:text-ink-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
      />
    </div>

    <button
      type="submit"
      class="submit-btn w-full bg-cta-600 hover:bg-cta-700 text-white font-medium rounded-md px-6 py-3 transition-colors"
    >
      Get My Free Quote
    </button>

    <div class="success-msg hidden text-center py-3">
      <p class="text-semantic-success font-medium">✓ Got it. We'll call you within 2 hours.</p>
    </div>
  </form>
</div>

<script define:vars={{ formId, source }}>
  const form = document.getElementById(formId);
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('.submit-btn');
      const msg = form.querySelector('.success-msg');
      btn.disabled = true;
      btn.textContent = 'Sending…';

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          form.reset();
          msg.classList.remove('hidden');
          btn.classList.add('hidden');
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'quote_submitted', source });
        } else {
          btn.textContent = 'Try Again';
          btn.disabled = false;
        }
      } catch {
        btn.textContent = 'Try Again';
        btn.disabled = false;
      }
    });
  }
</script>
