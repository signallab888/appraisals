---
const factors = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3.75h.75m-.75 3.75h.75m3-7.5h.75m-.75 3.75h.75m-.75 3.75h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" /></svg>`,
    title: "Property Type",
    body: "Office, retail, industrial, multifamily, hospitality, and specialty uses each require distinct methodologies, data sources, and comparable market analysis — directly shaping the scope of work.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" /></svg>`,
    title: "Size & Complexity",
    body: "Square footage, number of units, lease structure, and physical condition all affect how extensive the inspection and analysis must be. A simple warehouse and a multi-tenant mixed-use building are entirely different assignments.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>`,
    title: "Document Availability",
    body: "Rent rolls, leases, operating statements, and prior appraisals allow for faster, more precise analysis. Incomplete records require additional research and field verification, which extends the engagement.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: "Turnaround",
    body: "Standard delivery runs 7–10 business days. When a lender, closing, or court deadline requires an accelerated schedule, we accommodate rush requests — which affects the engagement scope accordingly.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.589-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.589-1.202L5.25 4.971z" /></svg>`,
    title: "Purpose of the Appraisal",
    body: "An appraisal for an SBA loan, an estate settlement, a tax appeal, or litigation each carries specific reporting requirements and standards of care under USPAP. The intended use defines how the report is structured and what it must contain.",
  },
];
---

<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14">
      <p class="text-xs font-bold uppercase tracking-widest text-cta-600 mb-3">Transparent Pricing</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-ink-800 tracking-tight mb-4">
        How We Price an Appraisal
      </h2>
      <p class="text-ink-500 text-lg max-w-2xl mx-auto">
        Every assignment is quoted individually — no online calculators, no hidden fees. Here are the five factors that shape every engagement.
      </p>
    </div>

    <!-- Factors grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {factors.map((f, i) => (
        <div class={`relative rounded-2xl border border-surface-border bg-surface-soft p-7 flex flex-col gap-4 transition-shadow hover:shadow-lg${i === 4 ? ' lg:col-start-2' : ''}`}>
          <!-- Number badge -->
          <div class="absolute top-5 right-6 text-5xl font-black text-brand-700/10 select-none leading-none">
            {i + 1}
          </div>
          <!-- Icon -->
          <div class="w-11 h-11 rounded-xl flex items-center justify-center text-brand-700" style="background-color: rgba(26,54,93,0.08);">
            <Fragment set:html={f.icon} />
          </div>
          <!-- Content -->
          <div>
            <h3 class="text-base font-bold text-ink-800 mb-2">{f.title}</h3>
            <p class="text-sm text-ink-500 leading-relaxed">{f.body}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA nudge -->
    <div class="mt-12 text-center rounded-2xl border border-brand-700/20 bg-brand-700/5 px-8 py-8">
      <p class="text-ink-700 font-semibold text-lg mb-1">Ready to get your quote?</p>
      <p class="text-ink-500 text-sm mb-5">We review your property details and respond within 2 hours — no commitment required.</p>
      <a
        href="#quote"
        class="inline-block bg-cta-600 hover:bg-cta-500 text-white font-bold rounded-lg px-8 py-3.5 text-sm transition-all duration-200 shadow-md shadow-cta-700/30 hover:shadow-lg hover:-translate-y-0.5"
      >
        Request a Free Quote →
      </a>
    </div>

  </div>
</section>
