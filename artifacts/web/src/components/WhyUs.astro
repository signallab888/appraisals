---
import business from '../data/business.json';

const points = [
  {
    title: 'State Certified General',
    body: `Jorge V. Canellas, ${business.primaryAppraiser.license}. Florida's highest commercial license level.`,
  },
  {
    title: 'MAI-Supported Reports',
    body: 'Backed by industry-standard methodology. Your bank and lender know exactly what that means.',
  },
  {
    title: `${business.yearsExperience} Years in Florida`,
    body: 'Deep local market data — not pulled from a national database. We know every submarket.',
  },
  {
    title: 'Fully Bilingual',
    body: 'Complete reports and consultation in English or Spanish. Atendemos en español.',
  },
  {
    title: 'FIRREA Compliant',
    body: 'Every report is written to pass lender review the first time. No re-work, no delays.',
  },
  {
    title: 'Court-Defensible',
    body: 'Testifying experience in Florida courts. USPAP-compliant from the first inspection note.',
  },
];
---

<section class="py-20 bg-brand-900 text-white relative overflow-hidden">
  <!-- Decorative background -->
  <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 25% 50%, #5a8bc4 0%, transparent 60%), radial-gradient(circle at 75% 50%, #ea580c 0%, transparent 60%);" />

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section label -->
    <div class="flex items-center gap-3 mb-4 justify-center">
      <div class="h-px w-12 bg-cta-500" />
      <span class="text-cta-400 text-xs font-bold uppercase tracking-widest">Why Choose Us</span>
      <div class="h-px w-12 bg-cta-500" />
    </div>

    <h2 class="text-3xl md:text-4xl font-extrabold text-white text-center tracking-tighter mb-14">
      Why Florida Banks and Attorneys<br class="hidden md:block" /> Rely on Us
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {points.map(p => (
        <div class="group flex gap-4 items-start p-6 rounded-xl bg-white/5 border border-white/8 hover:bg-white/10 hover:border-white/15 transition-all duration-300">
          <div class="w-9 h-9 rounded-lg bg-cta-600/20 border border-cta-500/30 flex items-center justify-center flex-shrink-0 mt-0.5 group-hover:bg-cta-600/30 transition-colors">
            <svg class="w-4.5 h-4.5 text-cta-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <p class="font-bold text-white mb-1.5">{p.title}</p>
            <p class="text-brand-300 text-sm leading-relaxed">{p.body}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom credential row -->
    <div class="mt-14 pt-10 border-t border-white/10 flex flex-wrap justify-center gap-4">
      {business.compliance.map(c => (
        <div class="bg-white/8 border border-white/12 rounded-full px-5 py-2 text-sm font-semibold text-brand-200">
          {c}
        </div>
      ))}
      <div class="bg-white/8 border border-white/12 rounded-full px-5 py-2 text-sm font-semibold text-brand-200">
        License RZ3108
      </div>
      <div class="bg-white/8 border border-white/12 rounded-full px-5 py-2 text-sm font-semibold text-brand-200">
        MAI-Supported
      </div>
    </div>
  </div>
</section>
