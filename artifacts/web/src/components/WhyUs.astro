---
import { Image } from 'astro:assets';
import appraiserPhoto from '../assets/about/jorge.png';
import business from '../data/business.json';

const points = [
  {
    title: 'State Certified General Appraiser · License RZ3108',
    body: `Florida's highest commercial license level, mandated by FIRREA for federally-related transactions.`,
  },
  {
    title: 'USPAP-Grade Methodology',
    body: 'Every report follows the Uniform Standards of Professional Appraisal Practice. Banks and lenders accept them the first time.',
  },
  {
    title: `${business.yearsExperience} Years in Florida`,
    body: 'Deep local market data — not pulled from a national database. We know every submarket.',
  },
  {
    title: 'Fully Bilingual',
    body: 'Complete reports and consultation in English or Spanish. Atendemos en español.',
  },
  {
    title: 'FIRREA Compliant',
    body: 'Every report is written to pass lender review the first time. No re-work, no delays.',
  },
  {
    title: 'Court-Defensible',
    body: 'Testifying experience in Florida courts. USPAP-compliant from the first inspection note.',
  },
];
---

<section class="py-20 bg-brand-900 text-white relative overflow-hidden" id="whyus">
  <!-- Subtle background glow -->
  <div class="absolute inset-0 opacity-8" style="background-image: radial-gradient(circle at 70% 50%, #3568a6 0%, transparent 55%);" />

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">

      <!-- Left: photo -->
      <div class="relative">
        <!-- Floating credential badge -->
        <div class="absolute -top-4 -right-4 z-20 bg-cta-600 text-white rounded-2xl px-5 py-3 shadow-xl shadow-cta-700/40 text-center">
          <p class="font-black text-2xl leading-none">{business.yearsExperience}</p>
          <p class="text-xs font-semibold mt-1 text-cta-100">Years in FL</p>
        </div>

        <div class="rounded-2xl overflow-hidden shadow-2xl shadow-brand-950/50">
          <!-- Photo + overlay all inside one relative container -->
          <div class="relative h-[420px] sm:h-[480px] lg:h-[560px]">
            <Image
              src={appraiserPhoto}
              alt="Jorge V. Canellas, State Certified General Appraiser"
              width={600}
              height={800}
              class="absolute inset-0 w-full h-auto"
              style="top: -80px;"
            />

            <!-- Dark gradient overlay — contained inside the rounded card -->
            <div class="absolute inset-0 bg-gradient-to-t from-brand-950 via-brand-950/60 to-transparent" />

            <!-- Name card at the bottom, also inside the relative container -->
            <div class="absolute bottom-0 left-0 right-0 px-6 pb-6">
              <p class="text-white font-bold text-lg leading-tight drop-shadow-lg">Jorge V. Canellas</p>
              <p class="text-brand-200 text-sm mt-1 drop-shadow">{business.primaryAppraiser.license} · State Certified General Appraiser</p>
              <div class="flex flex-wrap gap-2 mt-3">
                {business.compliance.slice(0, 3).map(c => (
                  <span class="bg-white/20 border border-white/30 text-white rounded-full px-3 py-1 text-xs font-semibold backdrop-blur-sm">{c}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: points -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px w-10 bg-cta-500" />
          <span class="text-cta-400 text-xs font-bold uppercase tracking-widest">Why Choose Us</span>
        </div>

        <h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tighter mb-10 leading-tight">
          Why Florida Banks and Attorneys<br class="hidden md:block" /> Rely on Us
        </h2>

        <div class="space-y-5">
          {points.map(p => (
            <div class="flex gap-4 items-start group">
              <div class="w-8 h-8 rounded-lg bg-cta-600/20 border border-cta-500/30 flex items-center justify-center flex-shrink-0 mt-0.5 group-hover:bg-cta-600/35 transition-colors">
                <svg class="w-4 h-4 text-cta-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <p class="font-bold text-white mb-1">{p.title}</p>
                <p class="text-brand-300 text-sm leading-relaxed">{p.body}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-10">
          <a
            href="#quote"
            class="block sm:inline-block w-full sm:w-auto text-center bg-cta-600 hover:bg-cta-500 text-white font-bold rounded-xl px-8 py-4 transition-all duration-200 shadow-lg shadow-cta-700/30 hover:shadow-xl hover:-translate-y-0.5 text-sm"
          >
            Get Your Free Quote →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
