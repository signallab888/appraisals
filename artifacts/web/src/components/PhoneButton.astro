---
import business from '../data/business.json';
---

<!-- App-style fixed bottom action bar — mobile only -->
<div class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex border-t border-white/10 shadow-2xl shadow-brand-950/60">

  <!-- Call button -->
  <a
    href={`tel:${business.phones.primary}`}
    class="flex-1 flex items-center justify-center gap-2.5 bg-brand-900 hover:bg-brand-800 text-white font-semibold text-sm py-4 transition-colors active:bg-brand-700"
    aria-label="Call us"
  >
    <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
      <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
    </svg>
    {business.phones.primary_display}
  </a>

  <!-- Divider -->
  <div class="w-px bg-white/10 self-stretch" />

  <!-- Get Quote button -->
  <a
    href="#quote"
    class="flex-1 flex items-center justify-center gap-2 bg-cta-600 hover:bg-cta-500 text-white font-semibold text-sm py-4 transition-colors active:bg-cta-700"
    aria-label="Get a free quote"
  >
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
    </svg>
    Get Free Quote
  </a>

</div>
