---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;

const rows = [
  { type: 'Multifamily 2–4 units',                               range: '$700 – $1,500',    highlight: false },
  { type: 'Standard commercial (office, retail, industrial)',     range: '$2,500 – $5,000',  highlight: true  },
  { type: 'Hotels, motels, going concern',                       range: '$5,000 – $10,000+', highlight: false },
  { type: 'Special purpose (church, marina, mobile home park)',  range: '$5,000 – $15,000+', highlight: false },
  { type: 'Narrative / litigation reports',                      range: '$5,000 – $12,000',  highlight: false },
];

const addons = [
  { label: 'Rush delivery', value: '+$500 – $2,000' },
  { label: 'Rental analysis add-on', value: '+$300 – $750' },
];
---

<section class={`${compact ? 'py-12' : 'py-20'} bg-white`} id="pricing">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    {!compact ? (
      <>
        <div class="flex items-center gap-3 mb-4 justify-center">
          <div class="h-px w-12 bg-cta-500" />
          <span class="text-cta-600 text-xs font-bold uppercase tracking-widest">Pricing</span>
          <div class="h-px w-12 bg-cta-500" />
        </div>
        <h2 class="text-3xl md:text-4xl font-extrabold text-ink-900 text-center tracking-tighter mb-3">
          How Much Does a Commercial<br class="hidden md:block" /> Appraisal Cost in Florida?
        </h2>
        <p class="text-ink-500 text-center mb-12">Real ranges. No hidden fees. Exact quote in 2 business hours.</p>
      </>
    ) : (
      <h3 class="text-xl font-bold text-ink-900 mb-6 tracking-tight">
        Typical Commercial Appraisal Fees in Florida
      </h3>
    )}

    <!-- Mobile: card stack -->
    <div class="sm:hidden space-y-3">
      {rows.map(r => (
        <div class={`rounded-2xl border px-5 py-4 flex justify-between items-center gap-3 ${r.highlight ? 'bg-brand-50 border-brand-200' : 'bg-white border-surface-line'}`}>
          <p class={`text-sm leading-snug ${r.highlight ? 'text-brand-900 font-semibold' : 'text-ink-700'}`}>
            {r.highlight && <span class="inline-block w-1.5 h-1.5 rounded-full bg-cta-500 mr-2 mb-0.5 align-middle" />}
            {r.type}
          </p>
          <p class="text-sm font-black text-ink-900 whitespace-nowrap">{r.range}</p>
        </div>
      ))}
    </div>

    <!-- Desktop: table -->
    <div class="hidden sm:block overflow-hidden rounded-2xl border border-surface-border shadow-sm">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-brand-800 text-white">
            <th class="text-left px-6 py-4 font-semibold text-sm tracking-wide">Property Type</th>
            <th class="text-right px-6 py-4 font-semibold text-sm tracking-wide">Typical Fee</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r, i) => (
            <tr class={`border-b border-surface-line/60 ${r.highlight ? 'bg-brand-50' : i % 2 === 0 ? 'bg-white' : 'bg-surface-soft/50'}`}>
              <td class="px-6 py-4 text-ink-700">
                {r.highlight && <span class="inline-block w-1.5 h-1.5 rounded-full bg-cta-500 mr-2 mb-0.5 align-middle" />}
                {r.type}
              </td>
              <td class="px-6 py-4 text-ink-900 font-bold text-right whitespace-nowrap">{r.range}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    {!compact && (
      <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
        {addons.map(a => (
          <div class="flex justify-between items-center bg-surface-soft rounded-xl px-5 py-3.5 text-sm border border-surface-line">
            <span class="text-ink-600">{a.label}</span>
            <span class="font-bold text-ink-900 ml-4">{a.value}</span>
          </div>
        ))}
      </div>
    )}

    <div class="mt-10 text-center">
      <a
        href="#quote"
        class="inline-block bg-cta-600 hover:bg-cta-500 text-white font-bold rounded-xl px-10 py-4 transition-all duration-200 shadow-lg shadow-cta-700/20 hover:shadow-xl hover:shadow-cta-700/30 hover:-translate-y-0.5 text-sm"
      >
        Get Your Exact Quote — Free
      </a>
      <p class="text-ink-400 text-xs mt-3">Typical response in 2 business hours · Mon–Fri 8am–6pm</p>
    </div>
  </div>
</section>
