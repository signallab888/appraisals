---
import appointmentIcon from '../assets/icons/icon-appointment.svg';
import clipboardIcon   from '../assets/icons/icon-clipboard.svg';
import costIcon        from '../assets/icons/icon-cost.svg';
import checkIcon       from '../assets/icons/icon-check.svg';

interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;

const steps = [
  {
    step: 'Step 1',
    title: 'Quote',
    body: 'Call or submit the form. We confirm scope, fee, and timeline within 2 business hours.',
    icon: appointmentIcon,
  },
  {
    step: 'Step 2',
    title: 'Inspection',
    body: 'Site visit, measurements, photos, and document collection — rent rolls, leases, financials.',
    icon: clipboardIcon,
  },
  {
    step: 'Step 3',
    title: 'Analysis',
    body: 'Income, sales comparison, and cost approach using Florida MLS, CoStar, and county records.',
    icon: costIcon,
  },
  {
    step: 'Step 4',
    title: 'Delivery',
    body: 'Restricted, Appraisal, or Narrative report delivered as signed PDF and digital copy.',
    icon: checkIcon,
  },
];
---

<section class={`${compact ? 'py-12' : 'py-20'} bg-brand-50`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {!compact && (
      <>
        <div class="flex items-center gap-3 mb-4 justify-center">
          <div class="h-px w-12 bg-cta-500" />
          <span class="text-cta-600 text-xs font-bold uppercase tracking-widest">Process</span>
          <div class="h-px w-12 bg-cta-500" />
        </div>
        <h2 class="text-3xl md:text-4xl font-extrabold text-ink-900 text-center tracking-tighter mb-14">
          From Quote to Delivered Report — Four Simple Steps
        </h2>
      </>
    )}
    {compact && (
      <h3 class="text-xl font-bold text-ink-900 mb-8 tracking-tight">From Quote to Delivered Report</h3>
    )}

    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
      <!-- Connecting line desktop -->
      <div class="hidden md:block absolute top-10 left-[12%] right-[12%] h-px bg-brand-200 z-0" />

      {steps.map((step) => (
        <div class="relative z-10 group flex flex-col items-center text-center">
          <!-- Icon circle -->
          <div class="w-20 h-20 rounded-full bg-white border-2 border-brand-200 group-hover:border-brand-500 flex items-center justify-center mb-5 shadow-md shadow-brand-900/10 transition-all duration-300 group-hover:shadow-lg group-hover:shadow-brand-900/15">
            <img
              src={step.icon.src}
              alt={step.title}
              width="36"
              height="36"
              class="w-9 h-9 object-contain"
              loading="lazy"
            />
          </div>

          <span class="text-xs font-bold text-cta-600 uppercase tracking-wider mb-1.5">{step.step}</span>
          <h3 class="font-bold text-ink-900 text-base mb-2">{step.title}</h3>
          {!compact && <p class="text-ink-500 text-sm leading-relaxed">{step.body}</p>}
        </div>
      ))}
    </div>
  </div>
</section>
