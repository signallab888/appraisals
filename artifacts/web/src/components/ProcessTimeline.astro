---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;

const steps = [
  {
    day: 'Day 0',
    title: 'Quote',
    body: 'You call or submit the form. We confirm scope, fee, and timeline within 2 business hours.',
  },
  {
    day: 'Days 1–3',
    title: 'Inspection',
    body: 'Site visit, measurements, photos, and document collection — rent rolls, leases, financials.',
  },
  {
    day: 'Days 4–10',
    title: 'Build',
    body: 'Income, sales comparison, and cost approach. Florida market data from MLS, CoStar, and county records.',
  },
  {
    day: 'Days 10–14',
    title: 'Delivery',
    body: 'Restricted, Appraisal, or Narrative report. PDF plus signed copy.',
  },
];
---

<section class={`${compact ? 'py-10' : 'py-16'} bg-brand-50`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {!compact && (
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-bold text-ink-800 tracking-tight">
          From Engagement to Report in 7–14 Days
        </h2>
      </div>
    )}
    {compact && (
      <h3 class="text-xl font-semibold text-ink-800 mb-6 tracking-tight">From Quote to Report in 7–14 Days</h3>
    )}

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 relative">
      {/* Connecting line — desktop only */}
      <div class="hidden md:block absolute top-8 left-[calc(12.5%+1rem)] right-[calc(12.5%+1rem)] h-0.5 bg-brand-200 z-0" />

      {steps.map((step, i) => (
        <div class="relative z-10 flex flex-col items-center text-center md:items-center">
          <div class="w-16 h-16 rounded-full bg-brand-700 text-white flex flex-col items-center justify-center mb-4 shadow-md flex-shrink-0">
            <span class="text-xs text-brand-300 leading-none">{step.day}</span>
            <span class="text-sm font-bold leading-tight mt-0.5">{step.title}</span>
          </div>
          {!compact && <p class="text-ink-600 text-sm leading-relaxed">{step.body}</p>}
        </div>
      ))}
    </div>
  </div>
</section>
