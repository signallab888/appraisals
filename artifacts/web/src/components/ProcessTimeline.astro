---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;

const steps = [
  {
    day: 'Day 0',
    title: 'Quote',
    body: 'Call or submit the form. We confirm scope, fee, and timeline within 2 business hours.',
    icon: 'M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z',
  },
  {
    day: 'Days 1–3',
    title: 'Inspection',
    body: 'Site visit, measurements, photos, and document collection — rent rolls, leases, financials.',
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
  },
  {
    day: 'Days 4–10',
    title: 'Analysis',
    body: 'Income, sales comparison, and cost approach using Florida MLS, CoStar, and county records.',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  },
  {
    day: 'Days 10–14',
    title: 'Delivery',
    body: 'Restricted, Appraisal, or Narrative report delivered as signed PDF and digital copy.',
    icon: 'M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
];
---

<section class={`${compact ? 'py-12' : 'py-20'} bg-brand-50`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {!compact && (
      <>
        <div class="flex items-center gap-3 mb-4 justify-center">
          <div class="h-px w-12 bg-cta-500" />
          <span class="text-cta-600 text-xs font-bold uppercase tracking-widest">Process</span>
          <div class="h-px w-12 bg-cta-500" />
        </div>
        <h2 class="text-3xl md:text-4xl font-extrabold text-ink-900 text-center tracking-tighter mb-14">
          From Engagement to Report in 7–14 Days
        </h2>
      </>
    )}
    {compact && (
      <h3 class="text-xl font-bold text-ink-900 mb-8 tracking-tight">From Quote to Report in 7–14 Days</h3>
    )}

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 relative">
      {/* Connecting line */}
      <div class="hidden md:block absolute top-8 left-[12.5%] right-[12.5%] h-px bg-brand-200 z-0" style="margin-left: 2.5rem; margin-right: 2.5rem;" />

      {steps.map((step, i) => (
        <div class="relative z-10 group">
          <div class="flex flex-col items-center text-center">
            <!-- Circle with icon -->
            <div class="w-16 h-16 rounded-full bg-brand-700 group-hover:bg-brand-800 text-white flex items-center justify-center mb-5 shadow-lg shadow-brand-900/20 transition-colors ring-4 ring-brand-50">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={step.icon} />
              </svg>
            </div>

            <span class="text-xs font-bold text-cta-600 uppercase tracking-wider mb-1">{step.day}</span>
            <h3 class="font-bold text-ink-900 text-base mb-2">{step.title}</h3>
            {!compact && <p class="text-ink-500 text-sm leading-relaxed">{step.body}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
