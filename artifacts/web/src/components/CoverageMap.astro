---
const regions = [
  {
    label: 'Central Florida',
    dotClass: 'bg-brand-500',
    borderStyle: 'border-left-color: #3568a6',
    cities: ['Orlando', 'Tampa', 'Lakeland', 'Kissimmee', 'Sanford', 'Lake Mary',
             'Winter Park', 'Ocala', 'Daytona Beach', 'Melbourne', 'Clermont'],
  },
  {
    label: 'South Florida',
    dotClass: 'bg-cta-600',
    borderStyle: 'border-left-color: #8B2035',
    cities: ['Miami', 'Fort Lauderdale', 'West Palm Beach', 'Boca Raton',
             'Hialeah', 'Doral', 'Coral Gables', 'Naples', 'Fort Myers', 'Cape Coral'],
  },
  {
    label: 'North Florida',
    dotClass: 'bg-brand-700',
    borderStyle: 'border-left-color: #1a365d',
    cities: ['Jacksonville', 'Gainesville', 'Tallahassee', 'Pensacola', 'St. Augustine'],
  },
];

const stats = [
  { n: '67', label: 'Counties Covered' },
  { n: '2',  label: 'Florida Offices' },
  { n: '20+', label: 'Years Experience' },
  { n: '2 hrs', label: 'Quote Response' },
];
---

<section class="py-24 bg-brand-50" id="coverage">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left: Florida map + stats grid -->
      <div class="flex flex-col items-center lg:items-start gap-10">
        <img
          src="/florida-state-simple.svg"
          alt="Florida state coverage map"
          width="480"
          height="480"
          class="w-72 sm:w-88 lg:w-full max-w-sm h-auto mx-auto lg:mx-0"
          loading="lazy"
        />

        <!-- Stats 2×2 grid under map -->
        <div class="grid grid-cols-2 gap-4 w-full max-w-sm mx-auto lg:mx-0">
          {stats.map(s => (
            <div class="bg-white border border-surface-line rounded-2xl p-5 text-center shadow-sm">
              <p class="text-3xl font-black text-brand-900 mb-1">{s.n}</p>
              <p class="text-ink-500 text-sm">{s.label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: heading + region cards -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px w-10 bg-cta-600" />
          <span class="text-cta-600 text-xs font-bold uppercase tracking-widest">Coverage</span>
        </div>

        <h2 class="text-3xl md:text-4xl font-extrabold text-brand-900 tracking-tighter mb-4 leading-tight">
          Florida Statewide —<br /> All 67 Counties
        </h2>
        <p class="text-ink-600 mb-10 leading-relaxed">
          Two offices. One point of contact. Appraisals anywhere in Florida — from Pensacola to Key West.
        </p>

        <div class="space-y-4">
          {regions.map(r => (
            <div
              class="bg-white border border-surface-line border-l-4 rounded-xl p-5 hover:shadow-md transition-shadow duration-300"
              style={r.borderStyle}
            >
              <div class="flex items-center gap-2.5 mb-3">
                <div class={`w-2.5 h-2.5 rounded-full flex-shrink-0 ${r.dotClass}`} />
                <h3 class="text-brand-900 font-bold text-sm">{r.label}</h3>
              </div>
              <div class="flex flex-wrap gap-2">
                {r.cities.map(city => (
                  <span class="bg-brand-50 border border-surface-line text-ink-600 rounded-full px-2.5 py-0.5 text-xs font-medium">
                    {city}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>
