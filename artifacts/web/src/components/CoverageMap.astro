---
const regions = [
  {
    label: 'Central Florida',
    color: 'bg-brand-700',
    cities: ['Orlando', 'Tampa', 'Lakeland', 'Kissimmee', 'Sanford', 'Lake Mary',
             'Winter Park', 'Ocala', 'Daytona Beach', 'Melbourne', 'Clermont'],
  },
  {
    label: 'South Florida',
    color: 'bg-cta-600',
    cities: ['Miami', 'Fort Lauderdale', 'West Palm Beach', 'Boca Raton',
             'Hialeah', 'Doral', 'Coral Gables', 'Naples', 'Fort Myers', 'Cape Coral'],
  },
  {
    label: 'North Florida',
    color: 'bg-brand-500',
    cities: ['Jacksonville', 'Gainesville', 'Tallahassee', 'Pensacola', 'St. Augustine'],
  },
];
---

<section class="py-20 bg-brand-900 text-white" id="coverage">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="flex items-center gap-3 mb-4 justify-center">
      <div class="h-px w-12 bg-cta-500" />
      <span class="text-cta-400 text-xs font-bold uppercase tracking-widest">Coverage</span>
      <div class="h-px w-12 bg-cta-500" />
    </div>

    <h2 class="text-3xl md:text-4xl font-extrabold text-white text-center tracking-tighter mb-4">
      Florida Statewide — All 67 Counties
    </h2>
    <p class="text-brand-300 text-center mb-14 max-w-xl mx-auto">
      Two offices. One point of contact. Appraisals anywhere in Florida.
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      {regions.map(r => (
        <div class="bg-white/6 border border-white/10 rounded-2xl p-7 hover:bg-white/10 hover:border-white/20 transition-all duration-300">
          <!-- Region header -->
          <div class="flex items-center gap-3 mb-5">
            <div class={`w-3 h-3 rounded-full ${r.color} flex-shrink-0`} />
            <h3 class="text-white font-bold text-base">{r.label}</h3>
          </div>

          <!-- City list -->
          <div class="flex flex-wrap gap-2">
            {r.cities.map(city => (
              <span class="bg-white/8 border border-white/12 text-brand-300 rounded-full px-3 py-1 text-xs font-medium hover:bg-white/15 transition-colors">
                {city}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom stat bar -->
    <div class="mt-12 pt-10 border-t border-white/10 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {[
        { n: '67', label: 'Counties Covered' },
        { n: '2',  label: 'Florida Offices' },
        { n: '20+', label: 'Years Experience' },
        { n: '2 hrs', label: 'Quote Response' },
      ].map(s => (
        <div>
          <p class="text-3xl font-black text-white mb-1">{s.n}</p>
          <p class="text-brand-400 text-sm">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
