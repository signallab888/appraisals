---
const regions = [
  {
    label: 'Central Florida',
    color: 'bg-brand-500',
    cities: ['Orlando', 'Tampa', 'Lakeland', 'Kissimmee', 'Sanford', 'Lake Mary',
             'Winter Park', 'Ocala', 'Daytona Beach', 'Melbourne', 'Clermont'],
  },
  {
    label: 'South Florida',
    color: 'bg-cta-500',
    cities: ['Miami', 'Fort Lauderdale', 'West Palm Beach', 'Boca Raton',
             'Hialeah', 'Doral', 'Coral Gables', 'Naples', 'Fort Myers', 'Cape Coral'],
  },
  {
    label: 'North Florida',
    color: 'bg-brand-300',
    cities: ['Jacksonville', 'Gainesville', 'Tallahassee', 'Pensacola', 'St. Augustine'],
  },
];
---

<section class="py-20 bg-brand-900 text-white" id="coverage">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">

      <!-- Left: Florida state shape -->
      <div class="flex justify-center lg:justify-start">
        <div class="relative">
          <!-- Glow behind the shape -->
          <div class="absolute inset-0 blur-3xl opacity-20 bg-brand-400 rounded-full scale-90" />
          <img
            src="/florida-state-simple.svg"
            alt="Florida state coverage map"
            width="420"
            height="420"
            class="relative w-64 sm:w-80 lg:w-96 h-auto opacity-90"
            loading="lazy"
            onerror="this.style.display='none'"
          />

          <!-- Fallback decorative stat grid if SVG not public -->
          <div class="grid grid-cols-2 gap-4 mt-8 lg:mt-0">
            {[
              { n: '67', label: 'Counties' },
              { n: '2',  label: 'Offices' },
              { n: '20+', label: 'Years' },
              { n: '2 hrs', label: 'Quote' },
            ].map(s => (
              <div class="bg-white/8 border border-white/12 rounded-2xl p-5 text-center">
                <p class="text-3xl font-black text-white mb-1">{s.n}</p>
                <p class="text-brand-400 text-sm">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: content -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px w-10 bg-cta-500" />
          <span class="text-cta-400 text-xs font-bold uppercase tracking-widest">Coverage</span>
        </div>

        <h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tighter mb-4 leading-tight">
          Florida Statewide —<br /> All 67 Counties
        </h2>
        <p class="text-brand-300 mb-10 leading-relaxed">
          Two offices. One point of contact. Appraisals anywhere in Florida — from Pensacola to Key West.
        </p>

        <div class="space-y-5">
          {regions.map(r => (
            <div class="bg-white/6 border border-white/10 rounded-xl p-5 hover:bg-white/10 hover:border-white/20 transition-all duration-300">
              <div class="flex items-center gap-2.5 mb-3">
                <div class={`w-2.5 h-2.5 rounded-full ${r.color} flex-shrink-0`} />
                <h3 class="text-white font-bold text-sm">{r.label}</h3>
              </div>
              <div class="flex flex-wrap gap-2">
                {r.cities.map(city => (
                  <span class="bg-white/8 border border-white/12 text-brand-300 rounded-full px-2.5 py-0.5 text-xs font-medium">
                    {city}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom stat bar -->
    <div class="mt-14 pt-10 border-t border-white/10 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {[
        { n: '67', label: 'Counties Covered' },
        { n: '2',  label: 'Florida Offices' },
        { n: '20+', label: 'Years Experience' },
        { n: '2 hrs', label: 'Quote Response' },
      ].map(s => (
        <div>
          <p class="text-3xl font-black text-white mb-1">{s.n}</p>
          <p class="text-brand-400 text-sm">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
