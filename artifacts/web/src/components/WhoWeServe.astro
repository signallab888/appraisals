---
const cards = [
  {
    title: 'Banks & Lenders',
    body: 'We deliver USPAP and FIRREA-compliant reports that pass review the first time. SBA 504, SBA 7(a), refinance, OREO, and portfolio loans.',
  },
  {
    title: 'Attorneys & CPAs',
    body: 'Court-defensible appraisals for divorce, estate, probate, partnership disputes, and tax appeals. Expert witness available.',
  },
  {
    title: 'Property Owners & Investors',
    body: 'Pre-purchase due diligence, partnership buyouts, 1031 exchanges, internal valuations, and tax appeals. We explain the report so you can act on it.',
  },
];
---

<section class="py-16 bg-surface-soft" id="services">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-bold text-ink-800 text-center mb-10 tracking-tight">
      Banks, Attorneys, CPAs, and Property Owners
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {cards.map(c => (
        <div class="bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow border border-surface-line">
          <h3 class="text-lg font-semibold text-brand-700 mb-3">{c.title}</h3>
          <p class="text-ink-600 text-sm leading-relaxed">{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
