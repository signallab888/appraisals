---
const cards = [
  {
    title: 'Banks & Lenders',
    icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
    body: 'USPAP and FIRREA-compliant reports that pass review the first time. SBA 504, SBA 7(a), refinance, OREO, and portfolio loans.',
    tags: ['SBA Ready', 'FIRREA', 'OREO'],
  },
  {
    title: 'Attorneys & CPAs',
    icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
    body: 'Court-defensible appraisals for divorce, estate, probate, partnership disputes, and tax appeals. Expert witness available.',
    tags: ['Divorce', 'Estate', 'Expert Witness'],
  },
  {
    title: 'Owners & Investors',
    icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
    body: 'Pre-purchase due diligence, partnership buyouts, 1031 exchanges, internal valuations, and tax appeals.',
    tags: ['1031 Exchange', 'Due Diligence', 'Tax Appeal'],
  },
];
---

<section class="py-20 bg-white" id="services">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section label -->
    <div class="flex items-center gap-3 mb-4 justify-center">
      <div class="h-px w-12 bg-cta-500" />
      <span class="text-cta-600 text-xs font-bold uppercase tracking-widest">Who We Serve</span>
      <div class="h-px w-12 bg-cta-500" />
    </div>

    <h2 class="text-3xl md:text-4xl font-extrabold text-ink-900 text-center tracking-tighter mb-14">
      Banks, Attorneys, CPAs,<br class="hidden md:block" /> and Property Owners
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-7">
      {cards.map((c, i) => (
        <div class="group relative bg-white border border-surface-line rounded-2xl p-7 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-900/8 transition-all duration-300 hover:-translate-y-1">
          <!-- Accent line top -->
          <div class="absolute top-0 left-7 right-7 h-0.5 bg-gradient-to-r from-brand-700 to-brand-500 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300" />

          <!-- Number -->
          <div class="text-5xl font-black text-brand-100 mb-4 leading-none select-none">0{i + 1}</div>

          <h3 class="text-xl font-bold text-ink-900 mb-3 tracking-tight">{c.title}</h3>
          <p class="text-ink-600 text-sm leading-relaxed mb-5">{c.body}</p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2">
            {c.tags.map(t => (
              <span class="bg-brand-50 text-brand-700 text-xs font-semibold px-2.5 py-1 rounded-full border border-brand-100">{t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
