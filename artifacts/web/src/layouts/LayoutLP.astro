---
import '../styles/global.css';
import HeaderLP from '../components/HeaderLP.astro';
import FooterLP from '../components/FooterLP.astro';
import PhoneButton from '../components/PhoneButton.astro';

interface Props {
  title: string;
  description: string;
  schema?: object | object[];
}

const { title, description, schema } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex,follow" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://commercialappraiserfl.com/og/og-lp.jpg" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Schema JSON-LD -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(schema) ? schema : [schema])} />
  )}

  <!-- GTM placeholder -->
  <script is:inline>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-XXXXXXX');
  </script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('a[href^="tel:"]').forEach(function(a) {
        a.addEventListener('click', function() {
          window.dataLayer = window.dataLayer || [];
          dataLayer.push({ event: 'phone_click', phone: a.getAttribute('href').replace('tel:', '') });
        });
      });
    });
  </script>
</head>
<body class="bg-surface-white text-ink-800">
  <noscript>
    <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-XXXXXXX"
      height="0" width="0" style="display:none;visibility:hidden"></iframe>
  </noscript>

  <HeaderLP />
  <main>
    <slot />
  </main>
  <FooterLP />
  <PhoneButton />
</body>
</html>
